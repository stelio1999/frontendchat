{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": false,                  // ◀️ Desativado para passar no deploy
    "noUnusedLocals": false,           // ◀️ Ignora os avisos de imports não lidos
    "noUnusedParameters": false,       // ◀️ Ignora os parâmetros não usados
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "types": ["vite/client"]           // ◀️ Resolve o erro do ImportMeta.env
  },
  "include": ["src"],
  "references": [{ "path": "./tsconfig.node.json" }]
}